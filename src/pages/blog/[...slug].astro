---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<PageLayout title={post.data.title} description={post.data.description}>
  <Container>
    <div class="animate">
      <BackToPrev href="/blog">
        Back to blog
      </BackToPrev>
    </div>
    <header class="space-y-4 my-10">
      <div class="animate flex items-center gap-1.5">
        {post.data.category && (
          <>
            <div class="font-base text-sm text-black/50 dark:text-white/60">
              {post.data.category}
            </div>
            &bull;
          </>
        )}
        <div class="font-base text-sm text-black/50 dark:text-white/60">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm text-black/50 dark:text-white/60">
          {readingTime(post.body)}
        </div>
      </div>
      <h1 class="animate text-4xl font-semibold leading-tight text-black dark:text-white">
        {post.data.title}
      </h1>
      <p class="animate text-lg leading-relaxed text-black/50 dark:text-white/60">
        {post.data.description}
      </p>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="animate flex flex-wrap gap-2 text-sm text-black/50 dark:text-white/60">
          {post.data.tags.map((tag) => (
            <span class="rounded border border-black/10 px-2 py-1 dark:border-white/15">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
